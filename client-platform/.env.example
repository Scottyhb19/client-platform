# =============================================================================
# Environment Variables — copy to .env and fill in values
# =============================================================================

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/client_platform?schema=public"

# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Resend (email) — sign up at resend.com, free tier = 100 emails/day
RESEND_API_KEY=
FROM_EMAIL="Practice Name <onboarding@resend.dev>"
PRACTICE_EMAIL=your@email.com

# Twilio (SMS) — set TWILIO_ENABLED=true when ready to send
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
