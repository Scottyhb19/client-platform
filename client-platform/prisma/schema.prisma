// =============================================================================
// Client Platform — Prisma Schema
// =============================================================================
// Data model for an Exercise Physiology practice management platform.
// Designed for single-practitioner v1 with multi-tenancy architecture baked in.
// Soft-delete on all clinical entities (Privacy Act 1988 — 7-year retention).
// =============================================================================

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// PRACTICE (multi-tenancy anchor)
// =============================================================================

model Practice {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  address   String?
  timezone  String   @default("Australia/Sydney")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  clients            Client[]
  exercises          Exercise[]
  exerciseTags       ExerciseTag[]
  sectionTitles      SectionTitle[]
  clientCategories   ClientCategory[]
  programTemplates   ProgramTemplate[]
  availabilitySlots  AvailabilitySlot[]
  settings           PracticeSetting[]
  auditLogs          AuditLog[]

  @@map("practices")
}

// =============================================================================
// USERS (staff — EP practitioners)
// =============================================================================

enum UserRole {
  OWNER
  PRACTITIONER
}

model User {
  id         String   @id @default(cuid())
  practiceId String
  clerkId    String?  @unique // Clerk external auth ID
  email      String   @unique
  firstName  String
  lastName   String
  role       UserRole @default(PRACTITIONER)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  practice          Practice           @relation(fields: [practiceId], references: [id])
  assignedClients   Client[]           @relation("AssignedPractitioner")
  createdPrograms   Program[]          @relation("ProgramCreatedBy")
  createdTemplates  ProgramTemplate[]  @relation("TemplateCreatedBy")
  clinicalNotes     ClinicalNote[]
  bookings          Booking[]          @relation("BookingPractitioner")
  communications    Communication[]
  auditLogs         AuditLog[]

  @@index([practiceId])
  @@map("users")
}

// =============================================================================
// CLIENTS
// =============================================================================

model Client {
  id             String    @id @default(cuid())
  practiceId     String
  practitionerId String?   // assigned EP
  clerkId        String?   @unique // Clerk external auth ID for portal login
  email          String
  firstName      String
  lastName       String
  dateOfBirth    DateTime?
  phone          String?
  gender         String?
  address        String?

  // Clinical intake
  medicalHistory    String?  // free text, entered by EP
  referralSource    String?  // GP referral, self-referred, word of mouth, social media
  referredBy        String?  // referring practitioner name
  medications       String?
  injuries          String?
  contraindications String?
  goals             String?

  // Status
  isActive   Boolean   @default(true)
  categoryId String?
  invitedAt  DateTime?
  onboardedAt DateTime?
  archivedAt DateTime?
  deletedAt  DateTime? // soft delete

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  practice      Practice        @relation(fields: [practiceId], references: [id])
  practitioner  User?           @relation("AssignedPractitioner", fields: [practitionerId], references: [id])
  category      ClientCategory? @relation(fields: [categoryId], references: [id])
  programs      Program[]
  clinicalNotes ClinicalNote[]
  sessionLogs   SessionLog[]
  bookings      Booking[]
  communications Communication[]
  reports       Report[]

  @@unique([practiceId, email])
  @@index([practiceId])
  @@index([practitionerId])
  @@index([deletedAt])
  @@map("clients")
}

model ClientCategory {
  id         String  @id @default(cuid())
  practiceId String
  name       String  // Athlete, Rehab, Lifestyle, Golf, Osteoporosis, Neurological
  sortOrder  Int     @default(0)

  practice Practice @relation(fields: [practiceId], references: [id])
  clients  Client[]

  @@unique([practiceId, name])
  @@map("client_categories")
}

// =============================================================================
// EXERCISE LIBRARY
// =============================================================================

enum MovementPattern {
  PUSH
  PULL
  SQUAT
  HINGE
  CARRY
  CORE
  ISOMETRIC
  OTHER
}

model Exercise {
  id              String          @id @default(cuid())
  practiceId      String
  name            String
  movementPattern MovementPattern @default(OTHER)
  videoUrl        String?         // YouTube link
  instructions    String?         // coaching cues, common errors, contraindications
  usageCount      Int             @default(0)

  // Default prescription (auto-populates when added to a program)
  defaultSets     Int?
  defaultReps     String?         // e.g. "8-12" or "10"
  defaultRest     String?         // e.g. "60s" or "2min"
  defaultRpe      Int?            // 1-10
  defaultMetric   String?         // kg, time, distance, percentage, tempo, bodyweight
  defaultLoad     String?         // e.g. "40" (interpreted with metric)

  deletedAt DateTime? // soft delete
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  practice         Practice          @relation(fields: [practiceId], references: [id])
  tags             ExerciseTag[]     @relation("ExerciseToTag")
  programExercises ProgramExercise[]
  templateExercises TemplateExercise[]

  @@index([practiceId])
  @@index([movementPattern])
  @@index([deletedAt])
  @@map("exercises")
}

model ExerciseTag {
  id         String @id @default(cuid())
  practiceId String
  name       String // DGR, PRI, Plyometrics, Rehab, Prehab — practitioner-configurable
  sortOrder  Int    @default(0)

  practice  Practice   @relation(fields: [practiceId], references: [id])
  exercises Exercise[] @relation("ExerciseToTag")

  @@unique([practiceId, name])
  @@map("exercise_tags")
}

// =============================================================================
// SECTION TITLES (practitioner-configurable per-exercise section labels)
// =============================================================================

model SectionTitle {
  id         String @id @default(cuid())
  practiceId String
  name       String // Mobility, Strength, Hypertrophy, Conditioning, etc.
  sortOrder  Int    @default(0)

  practice Practice @relation(fields: [practiceId], references: [id])

  @@unique([practiceId, name])
  @@map("section_titles")
}

// =============================================================================
// PROGRAM TEMPLATES (reusable, not tied to any client)
// =============================================================================

model ProgramTemplate {
  id          String  @id @default(cuid())
  practiceId  String
  createdById String
  name        String  // "ACL Rehab Phase 2", "General Strength 3x/wk"
  description String?
  type        String? // Home/Gym, In-Clinic

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  practice  Practice             @relation(fields: [practiceId], references: [id])
  createdBy User                 @relation("TemplateCreatedBy", fields: [createdById], references: [id])
  days      TemplateDayGroup[]
  programs  Program[]            @relation("ProgramFromTemplate")

  @@index([practiceId])
  @@map("program_templates")
}

model TemplateDayGroup {
  id         String @id @default(cuid())
  templateId String
  label      String // "Day A", "Day B", "Day C"
  sortOrder  Int    @default(0)

  template  ProgramTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  exercises TemplateExercise[]

  @@index([templateId])
  @@map("template_day_groups")
}

model TemplateExercise {
  id           String  @id @default(cuid())
  dayGroupId   String
  exerciseId   String
  sortOrder    Int     @default(0)
  sectionTitle String? // from SectionTitle list

  // Prescription overrides (null = use exercise defaults)
  sets         Int?
  reps         String?
  rest         String?
  rpe          Int?
  metric       String?
  load         String?
  instructions String?

  // Superset grouping
  supersetGroup String? // exercises with same group ID are superseted

  dayGroup TemplateDayGroup @relation(fields: [dayGroupId], references: [id], onDelete: Cascade)
  exercise Exercise         @relation(fields: [exerciseId], references: [id])

  @@index([dayGroupId])
  @@map("template_exercises")
}

// =============================================================================
// CLIENT PROGRAMS (living documents — the source of truth)
// =============================================================================

enum ProgramStatus {
  ACTIVE
  ARCHIVED
  DRAFT
}

enum ProgramType {
  HOME_GYM
  IN_CLINIC
}

model Program {
  id           String        @id @default(cuid())
  clientId     String
  createdById  String
  templateId   String?       // source template, if cloned
  name         String        // "Gym Program", "Home Program"
  type         ProgramType   @default(HOME_GYM)
  status       ProgramStatus @default(ACTIVE)
  startDate    DateTime?
  mesocycleWeeks Int?        // typically 4-6
  notes        String?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  client    Client           @relation(fields: [clientId], references: [id])
  createdBy User             @relation("ProgramCreatedBy", fields: [createdById], references: [id])
  template  ProgramTemplate? @relation("ProgramFromTemplate", fields: [templateId], references: [id])
  days      ProgramDayGroup[]
  sessionLogs SessionLog[]

  @@index([clientId])
  @@index([status])
  @@index([deletedAt])
  @@map("programs")
}

model ProgramDayGroup {
  id        String @id @default(cuid())
  programId String
  label     String // "Day A", "Day B", "Day C"
  sortOrder Int    @default(0)

  program   Program            @relation(fields: [programId], references: [id], onDelete: Cascade)
  exercises ProgramExercise[]

  @@index([programId])
  @@map("program_day_groups")
}

model ProgramExercise {
  id           String  @id @default(cuid())
  dayGroupId   String
  exerciseId   String
  sortOrder    Int     @default(0)
  sectionTitle String? // from SectionTitle list

  // Prescription (inherits from exercise defaults, EP overrides per-client)
  sets         Int?
  reps         String?
  rest         String?
  rpe          Int?
  metric       String?
  load         String?
  instructions String?

  // Superset grouping
  supersetGroup String?

  dayGroup     ProgramDayGroup    @relation(fields: [dayGroupId], references: [id], onDelete: Cascade)
  exercise     Exercise           @relation(fields: [exerciseId], references: [id])
  exerciseLogs ExerciseLog[]

  @@index([dayGroupId])
  @@map("program_exercises")
}

// =============================================================================
// SESSION LOGS (client-submitted workout data)
// =============================================================================

model SessionLog {
  id          String    @id @default(cuid())
  clientId    String
  programId   String
  dayLabel    String    // "Day A" — what training day was performed
  sessionRpe  Int?      // overall session RPE (1-10)
  feedback    String?   // "How are you feeling?" free text
  startedAt   DateTime?
  completedAt DateTime?
  durationMin Int?      // calculated from start/complete

  createdAt DateTime @default(now())

  client       Client        @relation(fields: [clientId], references: [id])
  program      Program       @relation(fields: [programId], references: [id])
  exerciseLogs ExerciseLog[]

  @@index([clientId])
  @@index([programId])
  @@index([completedAt])
  @@map("session_logs")
}

model ExerciseLog {
  id                String @id @default(cuid())
  sessionLogId      String
  programExerciseId String

  createdAt DateTime @default(now())

  sessionLog      SessionLog      @relation(fields: [sessionLogId], references: [id], onDelete: Cascade)
  programExercise ProgramExercise @relation(fields: [programExerciseId], references: [id])
  sets            SetLog[]

  @@index([sessionLogId])
  @@map("exercise_logs")
}

model SetLog {
  id            String  @id @default(cuid())
  exerciseLogId String
  setNumber     Int
  repsCompleted Int?
  loadUsed      String? // actual weight/value used
  rpe           Int?    // per-set RPE
  notes         String?

  createdAt DateTime @default(now())

  exerciseLog ExerciseLog @relation(fields: [exerciseLogId], references: [id], onDelete: Cascade)

  @@index([exerciseLogId])
  @@map("set_logs")
}

// =============================================================================
// CLINICAL NOTES
// =============================================================================

enum NoteType {
  INITIAL_ASSESSMENT
  PROGRESS_NOTE
  INJURY_FLAG
  CONTRAINDICATION
  DISCHARGE
  GENERAL
}

model ClinicalNote {
  id           String   @id @default(cuid())
  clientId     String
  authorId     String
  type         NoteType @default(GENERAL)
  title        String?
  content      String   // rich text / structured content
  isInjuryFlag Boolean  @default(false)
  flagReviewedAt DateTime? // when the EP last reviewed this flag
  isPinned     Boolean  @default(false)

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  client Client @relation(fields: [clientId], references: [id])
  author User   @relation(fields: [authorId], references: [id])

  @@index([clientId])
  @@index([clientId, type])
  @@index([isInjuryFlag])
  @@index([deletedAt])
  @@map("clinical_notes")
}

// =============================================================================
// SCHEDULING & BOOKINGS
// =============================================================================

model AvailabilitySlot {
  id            String   @id @default(cuid())
  practiceId    String
  dayOfWeek     Int?     // 0=Sunday, 6=Saturday (for recurring)
  specificDate  DateTime? // for one-off availability
  startTime     String   // "09:00" (HH:mm, 24h)
  endTime       String   // "17:00"
  slotDuration  Int      @default(60) // minutes per appointment
  isRecurring   Boolean  @default(true)
  isActive      Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  practice Practice @relation(fields: [practiceId], references: [id])

  @@index([practiceId])
  @@map("availability_slots")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

model Booking {
  id             String        @id @default(cuid())
  clientId       String
  practitionerId String
  date           DateTime      // appointment date
  startTime      String        // "10:00"
  endTime        String        // "11:00"
  status         BookingStatus @default(PENDING)
  type           String?       // "In-Clinic", "Telehealth"
  notes          String?       // pre-appointment notes
  reminderSentAt DateTime?     // when the 24h reminder was sent

  cancelledAt    DateTime?
  cancelReason   String?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  client       Client @relation(fields: [clientId], references: [id])
  practitioner User   @relation("BookingPractitioner", fields: [practitionerId], references: [id])

  @@index([clientId])
  @@index([practitionerId])
  @@index([date])
  @@index([status])
  @@index([deletedAt])
  @@map("bookings")
}

// =============================================================================
// COMMUNICATIONS (email log)
// =============================================================================

enum CommunicationType {
  EMAIL
  SMS
}

enum CommunicationStatus {
  DRAFT
  SENT
  FAILED
}

model Communication {
  id       String              @id @default(cuid())
  clientId String
  authorId String
  type     CommunicationType   @default(EMAIL)
  status   CommunicationStatus @default(DRAFT)
  subject  String?
  body     String
  sentAt   DateTime?

  createdAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id])
  author User   @relation(fields: [authorId], references: [id])

  @@index([clientId])
  @@index([sentAt])
  @@map("communications")
}

// =============================================================================
// REPORTS (VALD performance reports, Phase 3)
// =============================================================================

model Report {
  id        String   @id @default(cuid())
  clientId  String
  title     String   // "ForceDecks CMJ Assessment"
  testDate  DateTime
  content   String?  // rendered HTML or JSON data
  fileUrl   String?  // S3 path to uploaded report/CSV
  tags      String[] // VALD tags: "ForceDecks", "NordBord", etc.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id])

  @@index([clientId])
  @@index([testDate])
  @@map("reports")
}

// =============================================================================
// AUDIT LOG (compliance — who accessed/modified what)
// =============================================================================

model AuditLog {
  id         String   @id @default(cuid())
  practiceId String
  userId     String?
  action     String   // CREATE, READ, UPDATE, DELETE
  entity     String   // "Client", "ClinicalNote", "Program", etc.
  entityId   String?
  metadata   Json?    // additional context (old values, IP, etc.)
  createdAt  DateTime @default(now())

  practice Practice @relation(fields: [practiceId], references: [id])
  user     User?    @relation(fields: [userId], references: [id])

  @@index([practiceId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// =============================================================================
// PRACTICE SETTINGS (key-value store for practitioner preferences)
// =============================================================================

model PracticeSetting {
  id         String @id @default(cuid())
  practiceId String
  key        String // e.g. "default_mesocycle_weeks", "sms_enabled"
  value      String

  practice Practice @relation(fields: [practiceId], references: [id])

  @@unique([practiceId, key])
  @@map("practice_settings")
}
