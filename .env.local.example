# ============================================================================
# Environment variables — TEMPLATE
# ============================================================================
# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored; never commit secrets.
#
# Get values from Supabase dashboard:
#   https://supabase.com/dashboard/project/azjllcsffixswiigjqhj/settings/api
# ============================================================================

# Public — safe to ship to the browser
NEXT_PUBLIC_SUPABASE_URL=https://azjllcsffixswiigjqhj.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY-HERE

# Server-only — NEVER ship to the browser
# Used only in Server Actions / Route Handlers that legitimately bypass RLS.
# Rotated separately from anon key.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY-HERE
