# ============================================================================
# Environment variables — TEMPLATE
# ============================================================================
# Copy this file to .env.local and fill in the real values.
# .env.local is gitignored; never commit secrets.
#
# Get values from Supabase dashboard:
#   https://supabase.com/dashboard/project/YOUR-PROJECT-REF/settings/api
# ============================================================================

# ----------------------------------------------------------------------------
# Database (Supabase)
# ----------------------------------------------------------------------------

# Public — safe to ship to the browser
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY-HERE

# Server-only — NEVER ship to the browser
# Used only in Server Actions / Route Handlers that legitimately bypass RLS.
# Rotated separately from anon key.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY-HERE

# ----------------------------------------------------------------------------
# Email (Resend)
# ----------------------------------------------------------------------------

# Authenticates outbound transactional email (client invites, reminders).
RESEND_API_KEY=YOUR-RESEND-API-KEY-HERE

# Sender identity for all outbound email. RFC 5322 display-name form:
# "Display Name <address@verified-domain>". The address MUST be on a domain
# verified in Resend. Both code paths throw EmailConfigError if unset — there
# is no fallback. Example: EMAIL_FROM="OdysseyHQ <noreply@odysseyhq.com.au>"
EMAIL_FROM=YOUR-EMAIL-FROM-HERE

# ----------------------------------------------------------------------------
# URLs
# ----------------------------------------------------------------------------

# Flag E — NEXT_PUBLIC_SITE_URL and NEXT_PUBLIC_APP_URL must be kept in sync.
# The codebase reads both for different purposes (signup callback redirects
# and booking confirmation links respectively); if they drift,
# signup/booking confirmation URLs break. Reconciliation to a single
# variable is tracked as Flag E in docs/runbooks/README.md.
NEXT_PUBLIC_SITE_URL=YOUR-SITE-URL-HERE
NEXT_PUBLIC_APP_URL=YOUR-APP-URL-HERE

# ----------------------------------------------------------------------------
# Cron
# ----------------------------------------------------------------------------

# Bearer token the pg_cron caller presents to the send-appointment-reminders
# Edge Function. Any non-empty string — the Edge Function only checks it is
# set and non-blank, then exact-matches it as a Bearer token (no format
# enforced in code). Convention: generate with openssl rand -base64 32. See
# docs/runbooks/rotate-a-secret.md (two-place update: Edge secret + pg_cron).
CRON_SHARED_SECRET=YOUR-CRON-SHARED-SECRET-HERE

# ----------------------------------------------------------------------------
# Observability
# ----------------------------------------------------------------------------

# Optional. Leave unset to log to console only.
SENTRY_DSN=YOUR-SENTRY-DSN-HERE

# ----------------------------------------------------------------------------
# Reference only — auto-injected by platform, do not set in .env.local
# ----------------------------------------------------------------------------
# These are populated automatically at deploy/runtime. Setting them here has
# no effect — Vercel, Supabase, and Next.js override them. Listed only for a
# complete picture of what flows through the runtime.
VERCEL_URL=AUTO-INJECTED-BY-VERCEL-DO-NOT-SET
NODE_ENV=MANAGED-BY-NEXT-DO-NOT-SET
SUPABASE_URL=AUTO-INJECTED-BY-SUPABASE-EDGE-DO-NOT-SET
